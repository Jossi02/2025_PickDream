rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function currentUserData() {
      return get(/databases/$(database)/documents/User/$(request.auth.uid)).data;
    }

    function currentStudentId() {
      return ('studentId' in currentUserData())
        ? currentUserData().studentId
        : currentUserData().userID;
    }

    // ownerUid is the authority field. userID is the student number/display key.
    // Legacy documents without ownerUid are still accepted through userID fallback.
    function isDocumentOwner(data) {
      return isSignedIn() && (
        ('ownerUid' in data && data.ownerUid == request.auth.uid) ||
        (!('ownerUid' in data) && currentStudentId() == data.userID)
      );
    }

    function hasValidOwnerFields(data) {
      return isSignedIn()
        && ('ownerUid' in data)
        && data.ownerUid == request.auth.uid
        && ('userID' in data)
        && data.userID == currentStudentId();
    }

    function keepsOwnerFieldsStable(before, after) {
      return after.userID == before.userID
        && (
          !('ownerUid' in before) ||
          after.ownerUid == before.ownerUid
        );
    }

    match /User/{uid} {
      allow read, write: if request.auth.uid == uid;
    }

    match /User/{uid}/{subCollection=**} {
      allow read, write: if request.auth.uid == uid;
    }

    match /rooms/{roomId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    match /Notices/{noticeId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    match /Reviews/{reviewId} {
      allow read: if isSignedIn();
      allow create: if hasValidOwnerFields(request.resource.data);
      allow update: if isDocumentOwner(resource.data)
                    && isDocumentOwner(request.resource.data)
                    && keepsOwnerFieldsStable(resource.data, request.resource.data);
      allow delete: if isDocumentOwner(resource.data);
    }

    match /Reservations/{reservationId} {
      // Any signed-in user can read room schedules. Writes are limited to owned documents.
      allow read: if isSignedIn();
      allow create: if hasValidOwnerFields(request.resource.data);
      allow update: if isDocumentOwner(resource.data)
                    && isDocumentOwner(request.resource.data)
                    && keepsOwnerFieldsStable(resource.data, request.resource.data);
      allow delete: if isDocumentOwner(resource.data);
    }
  }
}
